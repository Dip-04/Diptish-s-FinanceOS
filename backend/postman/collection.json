{
  "info": {
    "name": "Diptish Gohane Finance OS API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000" }
  ],
  "item": [
    { "name": "Health", "request": { "method": "GET", "url": "{{baseUrl}}/health" } },
    { "name": "Income List", "request": { "method": "GET", "url": "{{baseUrl}}/api/income" } },
    { "name": "Create Income", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\"source_name\":\"Salary\",\"amount\":92000,\"income_type\":\"Salary\"}" }, "url": "{{baseUrl}}/api/income" } },
    { "name": "Expenses List", "request": { "method": "GET", "url": "{{baseUrl}}/api/expenses" } },
    { "name": "Create Expense", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\"expense_name\":\"Lunch\",\"category\":\"Food\",\"amount\":180,\"status\":\"Paid\"}" }, "url": "{{baseUrl}}/api/expenses" } },
    { "name": "Monthly Plans", "request": { "method": "GET", "url": "{{baseUrl}}/api/monthly-plans" } },
    { "name": "Loans List", "request": { "method": "GET", "url": "{{baseUrl}}/api/loans" } },
    { "name": "EMI List", "request": { "method": "GET", "url": "{{baseUrl}}/api/emis" } },
    { "name": "Savings List", "request": { "method": "GET", "url": "{{baseUrl}}/api/goals" } },
    { "name": "Purchase Planner List", "request": { "method": "GET", "url": "{{baseUrl}}/api/wishlist" } },
    { "name": "Reports Summary", "request": { "method": "GET", "url": "{{baseUrl}}/api/reports/summary" } }
  ]
}
